B2_APPLICATION_KEY=your-application-key
B2_REGION=us-west-004
B2_PUBLIC_URL=https://f004.backblazeb2.com/file/your-bucket-name

# Google Gemini
GEMINI_API_KEY=your-gemini-api-key

# App URLs
FRONTEND_URL=https://app.miniaturyallegro.pl
